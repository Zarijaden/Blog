/* 说说项样式 */
.talk-item {
  margin-bottom: 2rem;
  padding: 1.5rem;
  border-radius: 8px;
  background: var(--card-bg-color);
  box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}
.talk-header {
  display: flex;
  align-items: center;
  margin-bottom: 1rem;
}
.talk-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  margin-right: 1rem;
}
.talk-user {
  font-size: 1.1em;
}
.talk-time {
  font-size: 0.9em;
  color: #999;
}
.talk-content {
  line-height: 1.6;
}
.talk-content img {
  max-width: 100%;
  border-radius: 5px;
}